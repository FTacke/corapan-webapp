# Copy to .env for local overrides only. Do not commit .env.

# Core app mode
FLASK_ENV=development
FLASK_DEBUG=true

# Required secrets
FLASK_SECRET_KEY=<REQUIRED_FLASK_SECRET_KEY>
JWT_SECRET_KEY=<REQUIRED_JWT_SECRET_KEY>

# Required runtime boundaries
# Optional: add only when external GoatCounter tracking should be enabled.
# GOATCOUNTER_URL=https://corapan.goatcounter.com/count
CORAPAN_RUNTIME_ROOT=<WORKSPACE_ROOT>
CORAPAN_MEDIA_ROOT=<WORKSPACE_ROOT>\media

# Required auth/core database
AUTH_DATABASE_URL=postgresql+psycopg2://corapan_auth:corapan_auth@127.0.0.1:54320/corapan_auth

# Required BlackLab wiring when search is enabled
BLS_BASE_URL=http://localhost:8081/blacklab-server
BLS_CORPUS=corapan

# Common optional overrides
AUTH_HASH_ALGO=argon2
ALLOW_PUBLIC_TEMP_AUDIO=false
PUBLIC_STATS_DIR=<OPTIONAL_PUBLIC_STATS_DIR>
STATS_TEMP_DIR=<OPTIONAL_STATS_TEMP_DIR>
APP_REPOSITORY_URL=<OPTIONAL_REPOSITORY_URL>
APP_RELEASE_TAG=<OPTIONAL_RELEASE_TAG>
APP_RELEASE_URL=<OPTIONAL_RELEASE_URL>
START_ADMIN_USERNAME=<OPTIONAL_ADMIN_USERNAME>
START_ADMIN_PASSWORD=<OPTIONAL_ADMIN_PASSWORD>
